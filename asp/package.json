{
  "name": "predikt-oracle-asp",
  "version": "0.1.0",
  "private": true,
  "description": "Predikt Oracle \u2014 prediction-market toolkit for AI agents (OKX.AI A2MCP service): draft markets, estimate odds, suggest resolutions.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "mcp": "tsx src/mcp/index.ts",
    "bot": "tsx src/bots/run.ts",
    "bot:once": "BOT_ONCE=1 tsx src/bots/run.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.6.14",
    "tsx": "^4.19.2",
    "viem": "^2.55.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
